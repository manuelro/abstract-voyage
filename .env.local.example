CONTACT_DELIVERY_MODE=console

CONTACT_SMTP_HOST=<host>
CONTACT_SMTP_PORT=<port>
CONTACT_SMTP_SECURE=true
CONTACT_SMTP_USER=reach@abstract.voyage
CONTACT_SMTP_PASS=<app-password-here>

CONTACT_TO_EMAIL=reach@abstract.voyage
CONTACT_FROM_EMAIL=reach@abstract.voyage

CONTACT_FORCE_ERROR=false
CONTACT_FORCE_DELAY_MS=0

# Agent-assisted first contact (see netlify/functions/intake.js)
# Provider switch: "anthropic" (default) or "openai". Only the matching key below is required.
INTAKE_PROVIDER=anthropic
ANTHROPIC_API_KEY=<anthropic-api-key>
OPENAI_API_KEY=<openai-api-key>
# Gap-check model (decides whether a follow-up is needed, and generates it if
# so). Fast/cheap tier. Defaults to claude-haiku-4-5-20251001 (anthropic) or
# gpt-4o-mini (openai).
INTAKE_MODEL=
# Recap model (orders the visitor's own words for Manuel — the one artefact
# he actually reads). Strongest available tier, deliberately separate from
# INTAKE_MODEL above. Defaults to claude-sonnet-5 (anthropic) or gpt-4o (openai).
INTAKE_RECAP_MODEL=

# Optional in-memory per-IP rate limit across all intake stages. Best-effort
# only — does not survive a cold start or share state across concurrent
# function instances. Defaults: 12 requests per 10 minutes.
INTAKE_RATE_LIMIT_MAX=
INTAKE_RATE_LIMIT_WINDOW_MS=

# The agent discloses itself by this name (never a fabricated human persona,
# never a claimed role/profession). Function-side and browser-side must match.
AGENT_NAME=Relay
NEXT_PUBLIC_AGENT_NAME=Relay

# Optional response-time promise shown in the close message (e.g. "a day or
# two"). Leave unset unless it is a commitment that will actually be met —
# the clause is omitted entirely when this is empty.
NEXT_PUBLIC_REPLY_WINDOW_TEXT=

# Completed conversations are emailed to CONTACT_TO_EMAIL through the same
# CONTACT_SMTP_* config and CONTACT_DELIVERY_MODE console/smtp switch used by
# the contact form above (see netlify/functions/lib/mailer.js) — no separate
# email config needed. LEAD_WEBHOOK_URL is an optional *additional* forward
# (CRM/Slack/Sheet/etc), independent of email delivery; leave unset to only
# send the email.
LEAD_WEBHOOK_URL=