CONTACT_DELIVERY_MODE=console

CONTACT_SMTP_HOST=<host>
CONTACT_SMTP_PORT=<port>
CONTACT_SMTP_SECURE=true
CONTACT_SMTP_USER=reach@abstract.voyage
CONTACT_SMTP_PASS=<app-password-here>

CONTACT_TO_EMAIL=reach@abstract.voyage
CONTACT_FROM_EMAIL=reach@abstract.voyage

CONTACT_FORCE_ERROR=false
CONTACT_FORCE_DELAY_MS=0

# Guided intake form (see docs/intake-form-brief.md)
# Provider switch: "anthropic" (default) or "openai". Only the matching key below is required.
INTAKE_PROVIDER=anthropic
ANTHROPIC_API_KEY=<anthropic-api-key>
OPENAI_API_KEY=<openai-api-key>
# Optional override; defaults to claude-haiku-4-5-20251001 (anthropic) or gpt-4o-mini (openai).
INTAKE_MODEL=

# Persona injected into the model's system prompt (server-side only).
CONSULTANT_NAME=Maya Chen
CONSULTANT_ROLE=an independent brand & growth consultant for early-stage founders
# Same values, exposed to the browser for the UI header. Keep in sync with the pair above.
NEXT_PUBLIC_CONSULTANT_NAME=Maya Chen
NEXT_PUBLIC_CONSULTANT_ROLE=an independent brand & growth consultant for early-stage founders

# Completed leads are emailed to CONTACT_TO_EMAIL through the same CONTACT_SMTP_*
# config and CONTACT_DELIVERY_MODE console/smtp switch used by the contact form
# above (see netlify/functions/lib/mailer.js) — no separate email config needed.
# LEAD_WEBHOOK_URL is an optional *additional* forward (CRM/Slack/Sheet/etc);
# leave unset to only send the email.
LEAD_WEBHOOK_URL=